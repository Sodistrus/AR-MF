Program        = Manifest ;
Manifest       = "state" StateName "{" { Statement } "}" ;
StateName      = "IDLE" | "LISTENING" | "THINKING" | "RESPONDING" | "WARNING" | "ERROR" | "NIRODHA" ;
Statement      = IntentDecl | ConfidenceDecl | VisualBlock | RuleBlock ;
IntentDecl     = "intent" ":" String ;
ConfidenceDecl = "confidence" ":" Float ;
VisualBlock    = "visual" "{" { VisualParam } "}" ;
VisualParam    = ShapeDecl | ParticleDensity | Turbulence | FlowDirection | GlowIntensity | Palette ;
ShapeDecl      = "shape" ":" ShapeName ;
ParticleDensity = "particle_density" ":" Float ;
Turbulence     = "turbulence" ":" Float ;
FlowDirection  = "flow_direction" ":" ("inward" | "outward") ;
GlowIntensity  = "glow_intensity" ":" Float ;
Palette        = "palette" ":" PaletteName ;
RuleBlock      = "rule" "{" { Rule } "}" ;
Rule           = "enforce" RuleName | "if" Condition "then" Action ;
Condition      = Field CompOp Float ;
Field          = "turbulence" | "glow_intensity" | "particle_density" ;
CompOp         = ">" | "<" | ">=" | "<=" | "==" | "!=" ;
Action         = "clamp" | "reduce" | "override_visual_safe_mode" ;
RuleName       = "Patimokkha.NO_CHAOTIC_VISUAL" | "Patimokkha.SAFE_INTENSITY" | "Patimokkha.PROTECT_USER" ;
